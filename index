<!doctype html>
<html lang="cs">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>PM Store Bootstrap</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
</head>

<body>

<nav class="navbar navbar-expand-lg border-bottom sticky-top">
  <div class="container-xxl">
    <a class="navbar-brand" href="#">PM Store</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link active" href="#produkty">Produkty</a></li>
        <li class="nav-item"><a class="nav-link" href="#objednavky">Objednávky</a></li>
        <li class="nav-item"><a class="nav-link" href="#ucet">Účet</a></li>

        <li class="nav-item dropdown">
          <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Menu</a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#auto">Automatická objednávka</a></li>
            <li><a class="dropdown-item" href="#kontakt">Kontakt</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" data-bs-toggle="modal" data-bs-target="#supportModal" href="#">Podpora</a></li>
          </ul>
        </li>
      </ul>

      <button class="btn btn-outline-primary" data-bs-toggle="offcanvas" data-bs-target="#cartCanvas">
        Košík: <span id="cartCount">0</span>
      </button>
    </div>
  </div>
</nav>

<header class="container-xxl my-4">
  <div class="hero p-4 p-md-5">
    <div class="row align-items-center g-4">
      <div class="col-12 col-lg-7">
        <span class="badge badge-custom mb-3">Bootstrap projekt</span>
        <h1>Osobní účet a objednávky PM Store</h1>
        <p class="lead">
          Responzivní webová aplikace převedená z Qt projektu do HTML a Bootstrapu.
        </p>
        <button class="btn btn-light me-2" data-bs-toggle="modal" data-bs-target="#orderModal">
          Nová objednávka
        </button>
        <a href="#produkty" class="btn btn-outline-light">Zobrazit produkty</a>
      </div>

      <div class="col-12 col-lg-5">
        <img src="images/iqos.jpg" class="img-fluid rounded-4" alt="Produkt">
      </div>
    </div>
  </div>
</header>

<main class="container-xxl">

  <section class="row g-4 mb-4">
    <aside class="col-12 col-lg-3">
      <div class="card p-3 h-100">
        <h5>Osobní účet</h5>
        <p class="mb-1"><strong>Shakira Khamzina</strong></p>
        <p class="text-secondary">LOGIN: KHA0047</p>

        <button class="btn btn-primary mb-2" data-bs-toggle="modal" data-bs-target="#addressModal">
          Upravit adresu
        </button>

        <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#autoModal">
          Automatická objednávka
        </button>
      </div>
    </aside>

    <section class="col-12 col-lg-6" id="objednavky">
      <div class="card p-3">
        <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mb-3">
          <h5>Moje objednávky</h5>
          <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#orderModal">
            Přidat objednávku
          </button>
        </div>

        <div class="table-responsive">
          <table class="table table-striped table-hover align-middle">
            <thead>
              <tr>
                <th>ID</th>
                <th>Datum</th>
                <th>Produkt</th>
                <th>Stav</th>
                <th>Cena</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>2451</td>
                <td>12.03.2026</td>
                <td>IQOS ILUMA</td>
                <td><span class="badge text-bg-success">Doručeno</span></td>
                <td>1590 Kč</td>
              </tr>
              <tr>
                <td>2448</td>
                <td>01.03.2026</td>
                <td>TEREA Bronze</td>
                <td><span class="badge text-bg-info">Odesláno</span></td>
                <td>890 Kč</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <aside class="col-12 col-lg-3">
      <div class="card p-3 h-100">
        <h5>Vyhledávání</h5>

        <label class="form-label">ID objednávky</label>
        <div class="input-group mb-3">
          <input class="form-control" placeholder="např. 2451">
          <button class="btn btn-primary">Hledat</button>
        </div>

        <label class="form-label">Kategorie</label>
        <select class="form-select">
          <option>Vše</option>
          <option>Zařízení</option>
          <option>Náplně</option>
          <option>Příslušenství</option>
        </select>
      </div>
    </aside>
  </section>

  <section class="card p-3 mb-4" id="produkty">
    <h4>Produkty</h4>

    <div class="row g-3">
      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card p-3 h-100">
          <img src="images/r1.jpg" class="img-fluid product-img mb-3" alt="IQOS ILUMA">
          <h6>IQOS ILUMA</h6>
          <p class="fw-bold">1590 Kč</p>
          <button class="btn btn-primary add-cart">Přidat do košíku</button>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card p-3 h-100">
          <img src="images/r2.jpg" class="img-fluid product-img mb-3" alt="IQOS PRIME">
          <h6>IQOS ILUMA PRIME</h6>
          <p class="fw-bold">2490 Kč</p>
          <button class="btn btn-primary add-cart">Přidat do košíku</button>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card p-3 h-100">
          <img src="images/r3.jpg" class="img-fluid product-img mb-3" alt="Produkt">
          <h6>TEREA Silver</h6>
          <p class="fw-bold">890 Kč</p>
          <button class="btn btn-primary add-cart">Přidat do košíku</button>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-xl-3">
        <div class="card p-3 h-100">
          <img src="images/r4.jpg" class="img-fluid product-img mb-3" alt="Produkt">
          <h6>TEREA Bronze</h6>
          <p class="fw-bold">890 Kč</p>
          <button class="btn btn-primary add-cart">Přidat do košíku</button>
        </div>
      </div>
    </div>
  </section>

  <section class="card p-3 mb-4" id="ucet">
    <h4>Účet</h4>

    <ul class="nav nav-tabs">
      <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#profil">Profil</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#adresa">Adresa</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#nastaveni">Nastavení</button>
      </li>
    </ul>

    <div class="tab-content border border-top-0 p-3">
      <div class="tab-pane fade show active" id="profil">
        <div class="row g-3">
          <div class="col-12 col-md-6">
            <label class="form-label">Jméno</label>
            <input class="form-control" value="Shakira">
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label">Příjmení</label>
            <input class="form-control" value="Khamzina">
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label">E-mail</label>
            <input type="email" class="form-control" value="shakira@example.com">
          </div>
          <div class="col-12 col-md-6">
            <label class="form-label">Telefon</label>
            <input type="tel" class="form-control" value="+420 777 123 456">
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="adresa">
        <div class="row g-3">
          <div class="col-12 col-md-8">
            <label class="form-label">Ulice</label>
            <input class="form-control" value="Hlavní 25">
          </div>
          <div class="col-12 col-md-4">
            <label class="form-label">PSČ</label>
            <input class="form-control" value="702 00">
          </div>
        </div>
      </div>

      <div class="tab-pane fade" id="nastaveni">
        <div class="form-check form-check-inline">
          <input class="form-check-input" type="radio" name="theme" checked>
          <label class="form-check-label">Světlý režim</label>
        </div>

        <div class="form-check form-check-inline">
          <input class="form-check-input" type="radio" name="theme">
          <label class="form-check-label">Tmavý režim</label>
        </div>
      </div>
    </div>
  </section>

</main>

<footer class="container-xxl py-4 text-center">
  Bootstrap projekt — responzivní HTML aplikace
</footer>

<div class="modal fade" id="orderModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5>Nová objednávka</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <label class="form-label">Produkt</label>
        <select class="form-select mb-3">
          <option>IQOS ILUMA</option>
          <option>IQOS ILUMA PRIME</option>
          <option>TEREA Bronze</option>
        </select>

        <label class="form-label">Počet kusů</label>
        <input type="number" class="form-control" value="1" min="1">
      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Zavřít</button>
        <button class="btn btn-primary" data-bs-dismiss="modal">Uložit</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="addressModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5>Adresa doručení</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <input class="form-control mb-2" placeholder="Ulice">
        <input class="form-control mb-2" placeholder="Město">
        <input class="form-control" placeholder="PSČ">
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="autoModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5>Automatická objednávka</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <select class="form-select mb-3">
          <option>IQOS ILUMA</option>
          <option>TEREA Bronze</option>
        </select>

        <label class="form-label">Interval doručení</label>
        <input type="range" class="form-range" min="7" max="60" value="30">

        <div class="form-check">
          <input class="form-check-input" type="checkbox" checked>
          <label class="form-check-label">Posílat upozornění e-mailem</label>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="supportModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5>Podpora</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <textarea class="form-control" rows="4" placeholder="Popište problém"></textarea>
      </div>
    </div>
  </div>
</div>

<div class="offcanvas offcanvas-end" id="cartCanvas">
  <div class="offcanvas-header">
    <h5>Košík</h5>
    <button class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>

  <div class="offcanvas-body">
    <p id="cartText">Košík je prázdný.</p>
    <button class="btn btn-primary">Pokračovat k objednávce</button>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="script.js"></script>

</body>
</html>
